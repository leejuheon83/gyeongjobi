# Supabase 프로젝트 접속 정보 (Supabase 대시보드 > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# 첨부파일 설정
# 파일별 최대 크기(MB). 스토리지 버킷의 하드 리밋(10MB) 이하로 설정할 것
NEXT_PUBLIC_ATTACHMENT_MAX_FILE_MB=10

# 신청 접수 알림 이메일 (선택 사항 — 설정하지 않으면 이메일 발송을 건너뜀)
# Gmail SMTP로 발송. GMAIL_APP_PASSWORD는 로그인 비밀번호가 아니라
# 구글 계정 > 보안 > 앱 비밀번호에서 발급받는 16자리 값 (2단계 인증 필요)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# 알림 이메일에 넣을 검토 화면 링크의 기준 URL (없으면 링크 없이 발송)
SITE_URL=https://gyeongjobi.company.co.kr
